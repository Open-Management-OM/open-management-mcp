# ── Required ──────────────────────────────────────────────────────────────────
# These two variables must be set for the server to start.

# API key for the target service. For Neon: console.neon.tech >> Account >> API Keys
NEON_API_KEY=napi_your_key_here

# Bearer tokens that clients present to authenticate. JSON format.
# Each entry needs: token (any secure string), profile (role name), label (human-readable).
# Generate a token: openssl rand -base64 32
MCP_AUTH_TOKENS='{"tokens":[{"token":"tok_dev_abc123","profile":"admin","label":"Your Name"}]}'

# ── Security & RBAC ──────────────────────────────────────────────────────────
# All optional. Defaults are read-only safe.

# Custom RBAC role definitions. Uses category:verb permissions model.
# Default roles: admin, lead, member, finance, external, viewer.
# See README.md for full role/permission documentation.
# RBAC_PROFILES='{"admin":{"permissions":[{"category":"*","verb":"*"}]},"viewer":{"permissions":[{"category":"*","verb":"read"}]}}'

# Which API operations are callable. Array of {method, pathPattern} objects.
# Default: read-only GET endpoints only.
# ALLOWED_OPERATIONS='[{"method":"get","pathPattern":"^/projects$"}]'

# ── Performance ──────────────────────────────────────────────────────────────
# All optional with sensible defaults.

# Upstream API request timeout in milliseconds.
# REQUEST_TIMEOUT_MS=30000

# Maximum response body size in bytes (default: 1MB).
# MAX_RESPONSE_BYTES=1048576

# ── OAuth (required for Claude.ai desktop / web / mobile) ───────────────────
# Powers the Claude.ai custom connector flow. Set all four whenever your team
# will use the MCP from anywhere other than local Claude Code.

# OAUTH_CLIENT_ID=neon-mcp-client
# OAUTH_CLIENT_SECRET=your-secret-here
# OAUTH_JWT_SECRET=your-jwt-signing-secret
# PUBLIC_URL=https://mcp.yourdomain.com

# ── Database (for OAuth session storage) ─────────────────────────────────────
# Required whenever OAuth is enabled above.

# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── Microsoft SSO (pick this, Google SSO, or both) ──────────────────────────
# Entra (Azure AD) single-tenant. All four must be set.
# Role comes from Entra security group membership.
# See docs/microsoft-sso-setup.md for full walkthrough.

# MICROSOFT_TENANT_ID=00000000-0000-0000-0000-000000000000
# MICROSOFT_CLIENT_ID=00000000-0000-0000-0000-000000000000
# MICROSOFT_CLIENT_SECRET=your-client-secret
# MICROSOFT_GROUP_PROFILES='{"group-guid-admin":"admin","group-guid-readonly":"viewer"}'

# ── Google SSO (pick this, Microsoft SSO, or both) ──────────────────────────
# Google Workspace or personal accounts. All three must be set.
# Role comes from an explicit email allowlist-- anyone not on the list is denied.
# See docs/google-sso-setup.md for full walkthrough.

# GOOGLE_CLIENT_ID=123-abc.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_EMAIL_PROFILES='{"you@co.com":"admin","teammate@co.com":"viewer"}'

# ── Custom Auth (team-managed users with TOTP 2FA) ──────────────────────────
# For teams that don't want to set up an IdP. Users live in a Neon table,
# password-based login, TOTP 2FA enforced on first sign-in, AES-256-GCM
# encryption of the TOTP secret at rest. Admin UI lives at /api/admin.
# See docs/custom-auth-setup.md for the full walkthrough.

# 64 hex chars (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CUSTOM_AUTH_ENCRYPTION_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Admin token gates the /api/admin user-management UI. Use a long random string:
#   openssl rand -base64 32
# CUSTOM_AUTH_ADMIN_TOKEN=replace-with-a-long-random-string

# Issuer shown in authenticator apps (default: "Claude MCP")
# CUSTOM_AUTH_ISSUER="Acme MCP"
